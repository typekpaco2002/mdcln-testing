# =============================================================================
# ModelClone — environment template (copy to .env and fill in values)
# Safe to commit. Replace placeholders; never commit a real .env file.
# =============================================================================

# ---- Core ----
NODE_ENV=development
PORT=5000
SERVER_PORT=5000
# BODY_LIMIT=50mb

# Database (required in production)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Auth (required in production — server refuses weak defaults when NODE_ENV=production)
JWT_SECRET=generate-a-long-random-string-min-32-chars
# Telegram Mini App/Bot token used to verify WebApp initData and call Bot API.
TELEGRAM_BOT_TOKEN=
# Secret token sent by Telegram in X-Telegram-Bot-Api-Secret-Token for webhook verification.
TELEGRAM_WEBHOOK_SECRET=
# Public Mini App URL opened by bot buttons/web app links.
TELEGRAM_MINI_APP_URL=https://modelclone.app
# Optional: salt for telemetry IP hashing (defaults to JWT_SECRET)
# TELEMETRY_IP_SALT=

# ---- Public URLs (CORS + redirects) ----
FRONTEND_URL=https://modelclone.app
CLIENT_URL=https://modelclone.app
# Comma-separated extra origins
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
VITE_API_URL=https://your-api-host.example.com

# ---- Callbacks (KIE + WaveSpeed webhooks must reach your API over HTTPS) ----
# Single base is enough; full URLs are derived unless you override:
#   KIE:     {CALLBACK_BASE_URL}/api/kie/callback
#   WaveSpeed: {CALLBACK_BASE_URL}/api/wavespeed/callback  (or WAVESPEED_CALLBACK_URL)
CALLBACK_BASE_URL=https://modelclone.app
# Optional: full override (must be https in production)
# KIE_CALLBACK_URL=https://modelclone.app/api/kie/callback
# WAVESPEED_CALLBACK_URL=https://modelclone.app/api/wavespeed/callback
# NEXT_PUBLIC_APP_URL=https://modelclone.app
# APP_PUBLIC_URL=https://modelclone.app
# PUBLIC_URL=https://modelclone.app
# APP_URL=https://modelclone.app
# VERCEL_URL=   # set automatically on Vercel

# Webhook verification (recommended in production)
# HMAC for KIE callbacks (see kie-callback.routes.js)
WEBHOOK_HMAC_KEY=generate-a-long-random-string
# WaveSpeed webhook signature (optional; if set, signatures are verified)
WAVESPEED_WEBHOOK_SECRET=

# WaveSpeed client timeouts (optional; defaults apply when unset)
# Longer submit timeout prevents aborting before WaveSpeed returns a requestId (needed to map webhooks).
# WAVESPEED_SUBMIT_TIMEOUT_MS=120000
# WAVESPEED_POLL_TIMEOUT_MS=60000

# ---- AI provider API keys (Admin → Provider balances uses these names) ----
KIE_API_KEY=
PIAPI_API_KEY=
# PIAPI_CALLBACK_URL=https://modelclone.app/api/piapi/callback
WAVESPEED_API_KEY=
OPENROUTER_API_KEY=
# NSFW Grok: always plain text to the sampler unless both are set:
#   NSFW_GROK_JSON_PROMPTS=structured  (exactly this string; "1"/"true" are ignored)
#   and not nudes-pack. Nudes pack is always plain text.
# NSFW_GROK_JSON_PROMPTS=structured
# Optional: use Admin → prompt template for nsfwTextPromptGenerator (default is in-code ZiT + POV only).
# NSFW_GROK_USE_ADMIN_TEXT_TEMPLATE=1
FAL_API_KEY=
# FAL_KEY=   # alias for FAL_API_KEY

# ---- Vercel Blob (KIE relay — KIE cannot fetch some R2 URLs; optional but recommended) ----
BLOB_READ_WRITE_TOKEN=
# When true (default if unset): mirrorToR2-style paths persist to Blob, not R2. Set false only if you need R2 for those paths when both are configured.
# FORCE_BLOB_ONLY_STORAGE=true
# Optional: max bytes for client Blob uploads (handleUpload token). Default ~5 TiB (Vercel Blob multipart). Set to match your provider/plan.
# BLOB_CLIENT_UPLOAD_MAX_BYTES=

# ---- Per-model media limits (optional — defaults in src/config/providerMediaConstraints.js) ----
# PROVIDER_LIMIT_KIE_NANO_BANANA_PRO_IMAGE_MAX_BYTES=
# PROVIDER_LIMIT_KIE_SEEDREAM_45_EDIT_MAX_IMAGE_URLS=   # default 10; set 14 if confirmed with KIE
# PROVIDER_LIMIT_KIE_SEEDREAM_45_EDIT_IMAGE_MAX_BYTES=
# PROVIDER_LIMIT_KIE_KLING_26_I2V_ALLOWED_DURATIONS=5,10
# PROVIDER_LIMIT_KIE_KLING_30_VIDEO_ALLOWED_DURATIONS=5,10
# PROVIDER_LIMIT_WS_SEEDREAM_V45_EDIT_IMAGE_MAX_BYTES=
# PROVIDER_LIMIT_WS_VIDEO_FACE_SWAP_MAX_BYTES=          # default 500MB (WS docs omit byte max)
# PROVIDER_LIMIT_WS_VIDEO_FACE_SWAP_MIN_SEC=
# PROVIDER_LIMIT_WS_VIDEO_FACE_SWAP_MAX_SEC=            # default 600 (10 min per WS)
# PROVIDER_LIMIT_WS_KLING_V2_AVATAR_TEXT_MAX_CHARS=     # default 5000 (ElevenLabs paid TTS alignment)
# PROVIDER_LIMIT_FAL_Z_IMAGE_TRAINER_ZIP_MAX_BYTES=     # default 500MB
# (see providerMediaConstraints.js for full list)

# ---- Redis (optional — shared mirror cache across Vercel instances)
# Vercel: install “Redis” from Marketplace → link to project → redeploy. REDIS_URL is injected automatically.
# Self-hosted / Easypanel: use TLS in production, e.g. rediss://:PASSWORD@host:6380/0
# REDIS_URL=redis://:PASSWORD@127.0.0.1:6379/0
# Fallbacks (if your provider uses them): UPSTASH_REDIS_URL, KV_URL, or REDIS_HOST + REDIS_PASSWORD + REDIS_PORT

# ---- NSFW / ComfyUI (RunPod) ----
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
# Per-worker overrides (all fall back to RUNPOD_ENDPOINT_ID if unset)
# RUNPOD_NSFW_ENDPOINT_ID=              # NSFW txt2img / img2img generation
# RUNPOD_MOTION_ENDPOINT_ID=            # NSFW motion-control video worker (runpod-mdcln-motion / github.com/mconqeuroror/motion)
# RUNPOD_UPSCALER_ENDPOINT_ID=          # SeedVR2 image upscaler
# Legacy env names (still supported as fallbacks)
# RUNPOD_MODELCLONE_X_ENDPOINT_ID=
# RUNPOD_SOULX_ENDPOINT_ID=
# Optional OpenRouter model for ModelClone-X auto prompt optimization (default: x-ai/grok-4, fallback: x-ai/grok-4.1-fast)
# MODELCLONE_X_PROMPT_MODEL=x-ai/grok-4
# SOULX_PROMPT_MODEL=x-ai/grok-4
# Optional full callback URL; if unset, uses CALLBACK_BASE_URL + /api/runpod/callback (?secret= if RUNPOD_WEBHOOK_SECRET set)
# RUNPOD_WEBHOOK_URL=https://YOUR_API/api/runpod/callback?secret=YOUR_SECRET
RUNPOD_WEBHOOK_SECRET=
# FAL_NSFW_ENDPOINT=
# NSFW_COMFY_STRIP_UNSUPPORTED=1
# NSFW_COMFY_USE_WORKFLOW_POST=1
# NSFW_COMFY_REFINER_FIX_SDXL=1
# NSFW_POLL_CONCURRENCY=5
# NSFW_RECOVERY_POLL_CONCURRENCY=8
# NSFW_STUCK_MAX_AGE_SEC=12000
# NSFW_MAX_RUNNING_MS=
# NSFW_MAX_WALL_MS=

# ---- fal.ai / Replicate (LoRA training callbacks, etc.) ----
# REPLICATE_API_TOKEN=

# ---- Stripe / crypto (main app with checkout only) ----
# On a second deployment that only exposes /api for integrators (no web checkout), set:
#   REQUIRE_PAYMENT_SECRETS=false
# so the server does not require STRIPE_* / NOWPAYMENTS_IPN_SECRET. Default unset = require in production.
# REQUIRE_PAYMENT_SECRETS=false

# ---- Stripe (DUAL ACCOUNT: legacy = old account, new = US LLC) ----
#
# All NEW credit purchases, NEW subscriptions, upgrades, and special-offer
# purchases go on the NEW (US LLC) account.
#
# The LEGACY (old) account stays connected ONLY to keep grandfathered
# subscriptions rebilling correctly until they cancel/expire on their own.
#
# Backwards compatibility: if you don't set STRIPE_LEGACY_* the code falls
# back to the original STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET / TESTING_STRIPE_SECRET_KEY,
# so a one-account deployment keeps working without changes.
#
# --- LEGACY account (rebills + portal for grandfathered subs) ---
STRIPE_LEGACY_SECRET_KEY=
TESTING_STRIPE_LEGACY_SECRET_KEY=
STRIPE_LEGACY_WEBHOOK_SECRET=
#
# --- NEW (US LLC) account (all new business) ---
STRIPE_NEW_SECRET_KEY=
TESTING_STRIPE_NEW_SECRET_KEY=
STRIPE_NEW_WEBHOOK_SECRET=
#
# --- Optional feature flag ---
# Set to false to instantly route all NEW operations back to LEGACY (rollback switch).
# Default: true.
# STRIPE_NEW_ACCOUNT_ENABLED=true
#
# --- Frontend (Vite) — NEW account publishable keys ---
# Required so Stripe.js in the browser looks up PaymentIntents on the same
# account that the backend created them on. If you only set the legacy
# VITE_STRIPE_PUBLIC_KEY users will get "No such payment_intent: pi_xxx".
VITE_STRIPE_NEW_PUBLIC_KEY=pk_live_...
VITE_STRIPE_NEW_TEST_PUBLIC_KEY=pk_test_...
# Optional: country used by Apple Pay / Google Pay button. Default "US".
# VITE_STRIPE_MERCHANT_COUNTRY=US
#
# --- Backwards-compatible single-account fallbacks (treated as LEGACY) ---
# Already-deployed servers can keep these populated; the dual-account factory
# uses them as the legacy fallback when STRIPE_LEGACY_* aren't set.
STRIPE_SECRET_KEY=
TESTING_STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# VITE_STRIPE_PUBLIC_KEY=
# VITE_STRIPE_TEST_PUBLIC_KEY=

# ---- NowPayments (crypto) ----
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
# NOWPAYMENTS_IPN_BASE_URL=

# ---- Email (SendGrid) ----
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@modelclone.app
ADMIN_EMAIL=support@modelclone.app
APP_NAME=ModelClone
# RESEND_API_KEY=   # referenced in health checks / optional provider

# ---- Voice / avatars ----
ELEVENLABS_API_KEY=
# ELEVEN_API_KEY=
# ELEVENLABS_KEY=
HEYGEN_API_KEY=

# ---- Firebase admin (if used) ----
# VITE_FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# ---- R2 / storage ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ---- Generation housekeeping ----
# Enable only if you intentionally want old completed generations auto-pruned
# ENABLE_GENERATION_AUTO_CLEANUP=false
# MAX_COMPLETED_GENERATIONS_PER_MODEL=200
# STUCK_GENERATIONS_CLEANUP_INTERVAL_MS=
# NSFW_STUCK_CLEANUP_MINUTES=200

# ---- KIE rate limits (optional) ----
# KIE_MAX_CONCURRENT=100
# KIE_MAX_SUBMISSIONS_PER_10S=20

# ---- FFmpeg worker (repurpose / transcoding) ----
FFMPEG_WORKER_URL=
FFMPEG_WORKER_API_KEY=
# FFMPEG_WORKER_FALLBACK_URL=
# FFMPEG_WORKER_JOB_TIMEOUT_MS=600000
# FFMPEG_WORKER_CALLBACK_SECRET=

# ---- Viral reels (Apify scraper) ----
# Backed by Apify `apify/instagram-reel-scraper`. ALL scraping happens through
# the cron pipeline / admin triggers — there is no on-demand refresh path, so
# user actions never trigger paid Apify runs. Expired CDN URLs return
# `video_expired` until the next scheduled scrape.
APIFY_API_TOKEN=
# Optional: override the actor id (default `apify/instagram-reel-scraper`).
# APIFY_REEL_ACTOR_ID=apify/instagram-reel-scraper
# Optional: max seconds to wait for an actor run before timing out. Default 180.
# APIFY_REEL_WAIT_SECS=180
# Optional: items requested per profile scrape. Default 27 (clamped 1-50).
# REEL_SCRAPE_RESULTS_LIMIT=27
# Optional: delay between profile scrapes inside the pipeline (ms). Default 1500.
# REEL_SCRAPE_DELAY_MS=1500
# Optional: hours before a row's media URLs are considered stale enough to
# re-mirror to R2 on the next scrape. Default 96.
# REEL_CACHE_TTL_HOURS=96
# Public list freshness rules — only show reels that meet BOTH:
#   - posted within REEL_POSTED_LOOKBACK_DAYS days
#   - scraped within REEL_SCRAPED_LOOKBACK_DAYS days
# Sorted newest-first by postedAt so old high-score reels can't sit on top.
# REEL_POSTED_LOOKBACK_DAYS=14
# REEL_SCRAPED_LOOKBACK_DAYS=7
# Set to 1 to disable all scrape triggers (admin + cron) without removing routes.
# REEL_SCRAPER_DISABLED=
#
# Legacy env vars from previous scraper backends are no longer used:
# INSTAGRAM_X_IG_APP_ID=  INSTAGRAM_USER_AGENT=  INSTAGRAM_SHORTCODE_DOC_ID=  INSTAGRAM_SESSIONID=
# REEL_SCRAPER_TIMEOUT_MS=
# REEL_SCRAPER_WORKER_URL=  REEL_SCRAPER_WORKER_SECRET=  REEL_SCRAPER_PYTHON=  REEL_SCRAPER_ROOT=
# REEL_SCRAPER_SCROLL_ROUNDS=  REEL_SCRAPER_SCROLL_DELAY_MS=  REEL_SCRAPER_INITIAL_WAIT_MS=
# REEL_SCRAPER_PROXY=  REEL_SCRAPER_PROXY_LIST=  REEL_SCRAPER_PROXY_FILE=  REEL_SCRAPER_PROXY_BYPASS=  REEL_SCRAPER_DISABLE_PROXY=

# ---- Cron / scheduled jobs ----
CRON_SECRET=

# ---- n8n / repurposer (optional) ----
# N8N_REPURPOSE_WEBHOOK_URL=
# N8N_CALLBACK_SECRET=

# ---- Telemetry (optional) ----
# TELEMETRY_REQUEST_SAMPLE_RATE=1
# TELEMETRY_SLOW_REQUEST_MS=4000
# TELEMETRY_INFRA_SNAPSHOT_INTERVAL_MS=
# ENDPOINT_HEALTHCHECK_INTERVAL_MS=

# ---- Cloudinary (scripts / legacy) ----
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ---- Dev / misc ----
# REPLIT_DEV_DOMAIN=
# RUN_STARTUP_DATA_FIXES=true
# SKIP_DB_PUSH=1
# NEON_DATABASE_URL=   # scripts only
# LORA_TRAINING_COST=500
# PRO_LORA_TRAINING_COST=1000

# ---- Upstash / Vercel Redis (optional — shared rate limits across instances) ----
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=   # Vercel KV alias
# KV_REST_API_TOKEN=

# ---- Global /api rate limit (per client IP; see src/middleware/rateLimiter.js) ----
# API_RATE_LIMIT_MAX=2000
# API_RATE_LIMIT_WINDOW_MS=900000
