{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --include=optional",
  "buildCommand": "npx prisma generate && node scripts/ensure-ffmpeg.js && npm run build",
  "outputDirectory": "dist/public",
  "crons": [
    {
      "path": "/api/viral-reels/cron-scrape",
      "schedule": "0 */8 * * *"
    },
    {
      "path": "/api/cron/kie-recovery",
      "schedule": "*/5 * * * *"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 300,
      "excludeFiles": "node_modules/{ffmpeg-static,ffprobe-static,@ffmpeg-installer}/**",
      "includeFiles": [
        "node_modules/proxy-agent/**",
        "attached_assets/nsfw_core_workflow.json"
      ]
    }
  },
  "headers": [
    {
      "source": "/api/kie/callback",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://api.kie.ai" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
