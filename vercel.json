{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --include=optional",
  "buildCommand": "node scripts/ensure-ffmpeg.js && npm run build",
  "outputDirectory": "dist/public",
  "crons": [
    {
      "path": "/api/cron/kie-recovery",
      "schedule": "*/5 * * * *"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 800,
      "excludeFiles": "node_modules/{ffmpeg-static,ffprobe-static,@ffmpeg-installer}/**",
      "includeFiles": "attached_assets/**,runpod-mdcln/workflows/**"
    }
  },
  "headers": [
    {
      "source": "/api/kie/callback",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://api.kie.ai" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    {
      "source": "/.well-known/apple-developer-merchantid-domain-association",
      "destination": "/api/index.js"
    },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
