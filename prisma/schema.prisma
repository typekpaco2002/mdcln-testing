generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                            String                  @id @default(uuid())
  email                         String                  @unique
  password                      String?
  name                          String?
  role                          String                  @default("user")
  isVerified                    Boolean                 @default(false)
  verificationCode              String?
  codeExpiresAt                 DateTime?
  subscriptionTier              String?
  subscriptionStatus            String                  @default("trial")
  subscriptionBillingCycle      String?
  stripeCustomerId              String?                 @unique
  stripeSubscriptionId          String?                 @unique
  maxModels                     Int                     @default(999)
  subscriptionCredits           Int                     @default(0)
  purchasedCredits              Int                     @default(0)
  creditsExpireAt               DateTime?
  credits                       Int                     @default(0)
  totalCreditsUsed              Int                     @default(0)
  imageCredits                  Int                     @default(0)
  videoCredits                  Int                     @default(0)
  imagesUsed                    Int                     @default(0)
  videosUsed                    Int                     @default(0)
  createdAt                     DateTime                @default(now())
  updatedAt                     DateTime                @updatedAt
  twoFactorEnabled              Boolean                 @default(false)
  twoFactorSecret               String?
  freeTrialGenerationId         String?
  hasUsedFreeTrial              Boolean                 @default(false)
  onboardingCompleted           Boolean                 @default(false)
  specialOfferEligible          Boolean                 @default(false)
  specialOfferLockedAt          DateTime?
  authProvider                  String                  @default("email")
  googleId                      String?                 @unique
  freeVideosCompleted           Int                     @default(0)
  affiliateBlocked              Boolean                 @default(false)
  referralAdvanced              Boolean                 @default(false)
  firstSaleAt                   DateTime?
  firstSaleEventType            String?
  allowCustomLoraTrainingPhotos Boolean                 @default(false)
  referralCode                  String?                 @unique
  referredByUserId              String?
  resetCode                     String?
  resetCodeExpiresAt            DateTime?
  premiumFeaturesUnlocked       Boolean                 @default(false)
  region                        String?
  marketingLanguage             String?
  subscriptionCancelledAt       DateTime?
  proAccess                     Boolean                 @default(false)
  affiliateAttribution          AffiliateAttribution?
  affiliateConversions          AffiliateConversion[]
  creditTransactions            CreditTransaction[]
  cryptoPayments                CryptoPayment[]
  draftTasks                    DraftTask[]
  generations                   Generation[]
  referredCommissions           ReferralCommission[]    @relation("ReferredCommissions")
  referralCommissions           ReferralCommission[]    @relation("ReferrerCommissions")
  referralPayoutRequests        ReferralPayoutRequest[]
  savedModels                   SavedModel[]
  modelVoices                   ModelVoice[]
  generatedVoiceAudios          GeneratedVoiceAudio[]
  avatars                       Avatar[]
  avatarVideos                  AvatarVideo[]
  referredBy                    User?                   @relation("UserReferrals", fields: [referredByUserId], references: [id])
  referrals                     User[]                  @relation("UserReferrals")

  @@index([referredByUserId])
}

model CreditTransaction {
  id               String    @id @default(uuid())
  userId           String
  amount           Int
  type             String
  description      String?
  paymentSessionId String?   @unique
  emailSentAt      DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([paymentSessionId])
  @@index([userId, createdAt])
}

model Generation {
  id              String      @id @default(uuid())
  userId          String
  modelId         String?
  type            String
  prompt          String
  duration        Int?
  resolution      String?
  creditsCost     Int
  actualCostUSD   Float?
  inputImageUrl   String?
  inputVideoUrl   String?
  outputUrl       String?
  replicateModel  String?
  status          String      @default("pending")
  errorMessage    String?
  createdAt       DateTime    @default(now())
  completedAt     DateTime?
  creditsRefunded Boolean     @default(false)
  isTrial         Boolean     @default(false)
  isNsfw          Boolean     @default(false)
  pipelinePayload Json? // when set, callback finds by imageTaskId and continues pipeline (e.g. image -> video)
  model           SavedModel? @relation(fields: [modelId], references: [id])
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([modelId])
  @@index([status])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model KieTask {
  id           String    @id @default(cuid())
  taskId       String    @unique
  provider     String    @default("kie")
  entityType   String
  entityId     String
  step         String?
  status       String    @default("processing") // processing | completed | failed
  outputUrl    String?
  errorMessage String?
  payload      Json?
  userId       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  completedAt  DateTime?

  @@index([entityType, entityId])
  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model SavedModel {
  id                   String              @id @default(uuid())
  userId               String
  name                 String
  photo1Url            String
  photo2Url            String
  photo3Url            String
  thumbnail            String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  status               String              @default("ready")
  isAIGenerated        Boolean             @default(false)
  aiGenerationParams   Json?
  loraStatus           String?
  loraUrl              String?
  loraTriggerWord      String?
  loraTrainedAt        DateTime?
  loraFalRequestId     String?
  loraError            String?
  nsfwUnlocked         Boolean             @default(false)
  /// When true, user can edit model photos/looks even if normally locked (admin unlock)
  looksUnlockedByAdmin Boolean             @default(false)
  faceReferenceUrl     String?
  nsfwOverride         Boolean             @default(false)
  loraSessionPaid      Boolean             @default(false)
  activeLoraId         String?
  age                  Int?
  savedAppearance      Json?
  paymentIntentId      String?
  /// ElevenLabs voice id (IVC or voice design); deleted on model delete / recreate
  elevenLabsVoiceId    String?
  /// "clone" | "design"
  elevenLabsVoiceType  String?
  elevenLabsVoiceName  String?
  /// Cached preview MP3 on R2 for UI / talking-head picker
  modelVoicePreviewUrl String?
  generations          Generation[]
  modelVoices          ModelVoice[]
  generatedVoiceAudios GeneratedVoiceAudio[]
  trainingImages       LoraTrainingImage[]
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainedLoras         TrainedLora[]
  avatars              Avatar[]

  @@index([userId])
  @@index([isAIGenerated])
  @@index([loraStatus])
}

model ModelVoice {
  id                String               @id @default(cuid())
  userId            String
  modelId           String
  provider          String               @default("elevenlabs")
  elevenLabsVoiceId String               @unique
  type              String
  name              String
  description       String?              @db.Text
  language          String?
  previewUrl        String?
  sampleAudioUrl    String?
  isDefault         Boolean              @default(false)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  model             SavedModel           @relation(fields: [modelId], references: [id], onDelete: Cascade)
  generatedAudios   GeneratedVoiceAudio[]

  @@index([userId, createdAt])
  @@index([modelId, createdAt])
  @@index([modelId, isDefault])
}

model GeneratedVoiceAudio {
  id                       String                @id @default(cuid())
  userId                   String
  modelId                  String
  voiceId                  String?
  script                   String                @db.Text
  characterCount           Int
  estimatedDurationSec     Int?
  actualDurationSec        Float?
  creditsCost              Int
  isRegeneration           Boolean               @default(false)
  sourceAudioId            String?
  status                   String                @default("completed")
  audioUrl                 String?
  errorMessage             String?
  voiceNameSnapshot        String?
  voiceTypeSnapshot        String?
  elevenLabsVoiceIdSnapshot String?
  previewUrlSnapshot       String?
  completedAt              DateTime?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  user                     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  model                    SavedModel            @relation(fields: [modelId], references: [id], onDelete: Cascade)
  voice                    ModelVoice?           @relation(fields: [voiceId], references: [id], onDelete: SetNull)
  sourceAudio              GeneratedVoiceAudio?  @relation("GeneratedVoiceAudioRegeneration", fields: [sourceAudioId], references: [id], onDelete: SetNull)
  regenerations            GeneratedVoiceAudio[] @relation("GeneratedVoiceAudioRegeneration")

  @@index([userId, createdAt])
  @@index([modelId, createdAt])
  @@index([voiceId, createdAt])
  @@index([sourceAudioId])
  @@index([status, createdAt])
}

model TrainedLora {
  id                String              @id @default(uuid())
  modelId           String
  name              String?
  status            String              @default("awaiting_images")
  loraUrl           String?
  triggerWord       String?
  trainedAt         DateTime?
  falRequestId      String?
  error             String?
  faceReferenceUrl  String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  defaultAppearance Json?
  trainingMode      String              @default("standard")
  trainingImages    LoraTrainingImage[]
  model             SavedModel          @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@index([status])
}

model LoraTrainingImage {
  id           String       @id @default(uuid())
  modelId      String
  imageUrl     String
  imageType    String       @default("general")
  imageIndex   Int          @default(0)
  status       String       @default("completed")
  prompt       String?
  errorMsg     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  generationId String?
  loraId       String?
  lora         TrainedLora? @relation(fields: [loraId], references: [id], onDelete: Cascade)
  model        SavedModel   @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@index([loraId])
  @@index([status])
}

model CryptoPayment {
  id           String    @id
  orderId      String    @unique
  userId       String
  credits      Int
  priceUsd     Float
  type         String
  status       String    @default("pending")
  invoiceUrl   String?
  paymentId    String?
  paidAmount   String?
  paidCurrency String?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model RepurposeJob {
  id           String            @id @default(uuid())
  userId       String
  copies       Int               @default(1)
  status       String            @default("completed")
  progress     Int? // 0-100 for serverless polling
  message      String? // status message for UI
  errorMessage String? // when status is "failed"
  createdAt    DateTime          @default(now())
  outputs      RepurposeOutput[]

  @@index([userId])
  @@index([userId, createdAt])
}

model RepurposeOutput {
  id        String       @id @default(uuid())
  jobId     String
  fileName  String
  fileUrl   String
  fileSize  Int?
  createdAt DateTime     @default(now())
  job       RepurposeJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

// Content reformatter: history of convert-to-format jobs; output stored in R2, kept ~1 month
model ConverterJob {
  id               String    @id @default(uuid())
  userId           String
  originalFileName String?
  outputUrl        String?
  outputExt        String?
  status           String    @default("processing") // processing | completed | failed
  errorMessage     String?
  createdAt        DateTime  @default(now())
  completedAt      DateTime?
  expiresAt        DateTime? // output available until (e.g. completedAt + 30 days)

  @@index([userId])
  @@index([userId, createdAt])
}

model ReelFinderProfile {
  id                String    @id @default(uuid())
  username          String    @unique
  instagramUrl      String
  isActive          Boolean   @default(true)
  followerCount     Int?
  avgViews          Float?
  avgViewsUpdatedAt DateTime?
  addedAt           DateTime  @default(now())
  lastScrapedAt     DateTime?
  scrapeCount       Int       @default(0)
  scrapeGroup       Int       @default(0)
  reels             Reel[]

  @@index([isActive])
  @@index([scrapeGroup])
}

model Reel {
  id                 String            @id @default(uuid())
  profileId          String
  instagramReelId    String            @unique
  reelUrl            String?
  thumbnailUrl       String?
  views              Int               @default(0)
  likes              Int               @default(0)
  comments           Int               @default(0)
  shares             Int               @default(0)
  caption            String?
  audioName          String?
  postedAt           DateTime?
  viralScore         Float             @default(0)
  viewsToAvgRatio    Float             @default(0)
  lastScoreUpdate    DateTime?
  createdAt          DateTime          @default(now())
  videoUrl           String?
  contentCategory    String?
  prevViews          Int?
  prevViewsAt        DateTime?
  viewsPerHour       Float?
  audioTrendBonus    Float             @default(0)
  lastScrapedAt      DateTime?
  momentumMultiplier Float             @default(1.0)
  scrapeTier         Int               @default(4)
  shareBonus         Float             @default(0)
  viewsPerHourPrev   Float?
  profile            ReelFinderProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([viralScore])
  @@index([postedAt])
  @@index([viewsPerHour])
  @@index([scrapeTier, lastScrapedAt])
  @@index([audioName, postedAt])
}

model ScrapeLog {
  id              String    @id @default(uuid())
  status          String    @default("running")
  profilesScraped Int?
  reelsFound      Int?
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?

  @@index([startedAt])
}

model SignupFingerprint {
  id                String   @id @default(uuid())
  ipAddress         String
  deviceFingerprint String
  userAgent         String?
  email             String?
  freeCreditsGiven  Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@index([ipAddress])
  @@index([deviceFingerprint])
  @@index([ipAddress, deviceFingerprint])
}

model EmailUnsubscribe {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([email])
}

model LoggedReferralSignupDraft {
  id                String    @id @default(uuid())
  referralCode      String
  referrerUserId    String
  ipAddress         String?
  deviceFingerprint String?
  userAgent         String?
  signup            Boolean   @default(false)
  signedUpUserId    String?
  matchedAt         DateTime?
  createdAt         DateTime  @default(now())

  @@index([referralCode])
  @@index([referrerUserId])
  @@index([ipAddress])
  @@index([deviceFingerprint])
  @@index([signup, createdAt])
}

model ReferralCommission {
  id                  String   @id @default(uuid())
  referrerUserId      String
  referredUserId      String
  purchaseAmountCents Int
  commissionCents     Int
  sourceType          String
  sourceId            String
  createdAt           DateTime @default(now())
  referredUser        User     @relation("ReferredCommissions", fields: [referredUserId], references: [id], onDelete: Cascade)
  referrerUser        User     @relation("ReferrerCommissions", fields: [referrerUserId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId, referredUserId])
  @@index([referrerUserId, createdAt])
  @@index([referredUserId, createdAt])
}

model ReferralPayoutRequest {
  id                 String    @id @default(uuid())
  userId             String
  amountCents        Int
  walletAddress      String
  status             String    @default("pending")
  processedByAdminId String?
  adminNote          String?
  requestedAt        DateTime  @default(now())
  processedAt        DateTime?
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, requestedAt])
  @@index([status, requestedAt])
}

model AdminAuditLog {
  id          String   @id @default(uuid())
  adminUserId String
  adminEmail  String?
  action      String
  targetType  String?
  targetId    String?
  detailsJson String?
  createdAt   DateTime @default(now())

  @@index([adminUserId, createdAt])
  @@index([action, createdAt])
}

model ApiRequestMetric {
  id             String   @id @default(uuid())
  method         String
  routePath      String
  normalizedPath String
  statusCode     Int
  durationMs     Int
  userId         String?
  isAdmin        Boolean  @default(false)
  ipHash         String?
  userAgent      String?
  requestBytes   Int?
  responseBytes  Int?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([normalizedPath, createdAt])
  @@index([statusCode, createdAt])
  @@index([userId, createdAt])
}

model TelemetryEdgeEvent {
  id          String   @id @default(uuid())
  eventType   String
  severity    String   @default("info")
  message     String?
  routePath   String?
  statusCode  Int?
  userId      String?
  ipHash      String?
  detailsJson String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([eventType, createdAt])
  @@index([severity, createdAt])
}

model SystemHealthMetric {
  id                String   @id @default(uuid())
  processUptimeSec  Int
  memoryRssMb       Float
  memoryHeapUsedMb  Float
  memoryHeapTotalMb Float
  eventLoopLagMs    Int?
  loadAvg1          Float?
  activeHandles     Int?
  activeRequests    Int?
  createdAt         DateTime @default(now())

  @@index([createdAt])
}

model ApiEndpointHealthSnapshot {
  id           String   @id @default(uuid())
  runId        String
  endpointKey  String
  method       String
  path         String
  status       String
  checksCount  Int      @default(0)
  errorRatePct Float?
  avgLatencyMs Int?
  message      String?
  checkedAt    DateTime @default(now())

  @@index([runId, checkedAt])
  @@index([endpointKey, checkedAt])
  @@index([status, checkedAt])
}

model AppBranding {
  id               String   @id @default("global")
  appName          String   @default("ModelClone")
  logoUrl          String?
  faviconUrl       String?
  baseUrl          String?
  tutorialVideoUrl String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model GenerationPricingConfig {
  id        String   @id @default("global")
  values    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Singleton (id = "global"): max custom ElevenLabs voices across all models (admin-editable)
model VoicePlatformConfig {
  id                        String   @id @default("global")
  maxCustomElevenLabsVoices Int      @default(200)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model AffiliatePartner {
  id            String                 @id @default(uuid())
  code          String                 @unique
  displayName   String
  email         String?
  isActive      Boolean                @default(true)
  payoutChain   String?
  payoutAddress String?
  payoutNote    String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  attributions  AffiliateAttribution[]
  clicks        AffiliateClick[]
  conversions   AffiliateConversion[]
  withdrawals   WithdrawalRequest[]

  @@index([isActive])
}

model AffiliateClick {
  id           String           @id @default(uuid())
  affiliateId  String
  codeSnapshot String
  landingPath  String?
  ipHash       String?
  userAgent    String?
  cookieId     String?
  createdAt    DateTime         @default(now())
  affiliate    AffiliatePartner @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId, createdAt])
  @@index([cookieId])
}

model AffiliateAttribution {
  id          String           @id @default(uuid())
  userId      String           @unique
  affiliateId String
  sourceType  String
  sourceRef   String?
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  affiliate   AffiliatePartner @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([expiresAt])
}

model AffiliateConversion {
  id             String           @id @default(uuid())
  userId         String
  affiliateId    String
  eventType      String
  eventRef       String
  grossUsd       Float
  commissionUsd  Float
  commissionRate Float            @default(0.15)
  status         String           @default("pending")
  isFirstSale    Boolean          @default(true)
  payoutTxHash   String?
  paidAt         DateTime?
  createdAt      DateTime         @default(now())
  affiliate      AffiliatePartner @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventType, eventRef])
  @@index([affiliateId, status])
  @@index([userId])
}

model WithdrawalRequest {
  id            String           @id @default(uuid())
  affiliateId   String
  amountUsd     Float
  cryptoChain   String
  cryptoAddress String
  status        String           @default("pending")
  txHash        String?
  adminNote     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  affiliate     AffiliatePartner @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([status])
}

model DiscountCode {
  id                String   @id @default(cuid())
  code              String   @unique
  discountType      String   @default("percentage")
  discountValue     Float
  appliesTo         String   @default("both")
  validFrom         DateTime @default(now())
  validUntil        DateTime
  maxUses           Int?
  currentUses       Int      @default(0)
  isActive          Boolean  @default(true)
  minPurchaseAmount Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([code])
  @@index([isActive])
}

model DraftTask {
  id        String   @id @default(cuid())
  userId    String
  feature   String
  data      Json
  imageUrls String[]
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, feature])
  @@index([userId])
}

/// Real Avatar — created from a photo using HeyGen Photo Avatar IV API
model Avatar {
  id             String        @id @default(uuid())
  userId         String
  modelId        String
  name           String
  /// processing | ready | failed | suspended
  status         String        @default("processing")
  photoUrl       String
  /// HeyGen avatar group ID returned on creation
  heygenGroupId  String?
  /// Specific avatar ID within the group (available once ready)
  heygenAvatarId String?
  errorMessage   String?
  creditsCost    Int           @default(1000)
  /// Last date monthly fee (500cr) was charged
  lastBilledAt   DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  model          SavedModel    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  videos         AvatarVideo[]

  @@index([userId])
  @@index([modelId])
}

/// Video generated with a Real Avatar
model AvatarVideo {
  id            String    @id @default(uuid())
  userId        String
  avatarId      String
  script        String    @db.Text
  heygenVideoId String?
  /// processing | completed | failed
  status        String    @default("processing")
  outputUrl     String?
  /// Actual duration in seconds (set when complete)
  duration      Float?
  creditsCost   Int
  errorMessage  String?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatar        Avatar    @relation(fields: [avatarId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([avatarId])
}
